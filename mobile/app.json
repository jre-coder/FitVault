{
  "expo": {
    "name": "FitVault",
    "slug": "fitvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fitvault",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elrcreative.fitvault",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.fitvault.app"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "./plugins/withAppGroup",
      [
        "expo-image-picker",
        {
          "photosPermission": "FitVault uses your photos to import workout plans.",
          "cameraPermission": "FitVault uses your camera to photograph workout plans."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "025c97db-b017-4b7f-8b64-76aa67be9405"
      }
    },
    "owner": "jen.elrcreative"
  }
}
